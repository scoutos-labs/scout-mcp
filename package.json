{
  "name": "scoutos-mcp",
  "version": "0.1.0-alpha.5",
  "description": "Local MCP server for the Scout OS API",
  "license": "MIT",
  "type": "module",
  "bin": {
    "scoutos-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scoutos-labs/scout-mcp.git"
  },
  "homepage": "https://github.com/scoutos-labs/scout-mcp#readme",
  "bugs": {
    "url": "https://github.com/scoutos-labs/scout-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scout",
    "scoutos",
    "agents"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "typescript": "^5.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "bun-types": "^1.2.13",
    "vitest": "^3.2.4"
  }
}
